global:
  scrape_interval: 5s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["prometheus:9090"]

  - job_name: "node_exporter"
    static_configs:
      - targets: [":9100"]

  - job_name: "app"
    static_configs:
      - targets:
          - "app1:5000"
          - "app2:5000"
          - "app3:5000"

  - job_name: "nginx"
    static_configs:
      - targets: ["reverse-proxy:80"]
